# 阿里云百炼：文生文档 / 文生图片 / 文生视频 / 语音合成
DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# DASHSCOPE_PROXY_URL=http://127.0.0.1:7897
# DASHSCOPE_TTS_VOICE=longxiaochun
# DASHSCOPE_TTS_RESPONSE_FORMAT=mp3
# DASHSCOPE_IMAGE_TASK_TIMEOUT_MS=180000
# DASHSCOPE_VIDEO_TASK_TIMEOUT_MS=300000

# Mistral：文生文档
MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_PROXY_URL=http://127.0.0.1:7897

# Replicate：国际版文档 / 图片 / 视频 / 音频
REPLICATE_API_TOKEN=
# REPLICATE_BASE_URL=https://api.replicate.com/v1
# REPLICATE_PROXY_URL=http://127.0.0.1:7897
# REPLICATE_DOCUMENT_GENERATION_MAX_NEW_TOKENS=800
# REPLICATE_DOCUMENT_SPREADSHEET_MAX_NEW_TOKENS=950
# REPLICATE_DOCUMENT_EDIT_SOURCE_MAX_CHARS=6000
# REPLICATE_DOCUMENT_DETECTION_MAX_NEW_TOKENS=220
# REPLICATE_DOCUMENT_DETECTION_MAX_COMPLETION_TOKENS=140
# REPLICATE_VISUAL_DETECTION_MAX_COMPLETION_TOKENS=140
# REPLICATE_DOCUMENT_DETECTION_SOURCE_MAX_CHARS=4000
# REPLICATE_MINIMAX_SPEECH_VOICE_ID=Wise_Woman
# REPLICATE_MINIMAX_SPEECH_VOICE_ID_EN=Wise_Woman
# REPLICATE_MINIMAX_SPEECH_VOICE_ID_ZH=
# REPLICATE_MINIMAX_SPEECH_AUDIO_FORMAT=mp3
# REPLICATE_MINIMAX_SPEECH_SAMPLE_RATE=24000
# REPLICATE_MINIMAX_SPEECH_BITRATE=64000
# REPLICATE_MINIMAX_SPEECH_CHANNEL=mono
# REPLICATE_MINIMAX_SPEECH_SPEED=1
# REPLICATE_MINIMAX_SPEECH_VOLUME=1
# REPLICATE_MINIMAX_SPEECH_PITCH=0
# REPLICATE_MINIMAX_SPEECH_LANGUAGE_BOOST=
# REPLICATE_MINIMAX_SPEECH_ENGLISH_NORMALIZATION=false

# 可选：统一代理兜底
# GEMINI_PROXY_URL=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897

# 版本隔离：zh=国内版 CloudBase，en=国际版 Supabase
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh

# CloudBase（国内版邮箱验证码认证）
NEXT_PUBLIC_CLOUDBASE_ENV_ID=
NEXT_PUBLIC_CLOUDBASE_REGION=ap-shanghai
NEXT_PUBLIC_CLOUDBASE_ACCESS_KEY=
# 可选兼容别名
# NEXT_PUBLIC_WECHAT_CLOUDBASE_ID=
# NEXT_PUBLIC_CLOUDBASE_API_KEY=
# 旧变量名兼容（由 next.config.js 自动映射）
# WECHAT_CLOUDBASE_ID=
# CLOUDBASE_REGION=ap-shanghai
# CLOUDBASE_ACCESS_KEY=

# Supabase（国际版/后台）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 游客文档月额度（仅未登录用户）
NEXT_PUBLIC_GUEST_MONTHLY_LIMIT=10

# 游客额度签名密钥（生产环境必填，建议 32+ 随机字符）
GUEST_QUOTA_VISITOR_SECRET=

# 管理后台会话签名密钥（生产环境必填）
ADMIN_SESSION_SECRET=

# 可选：导出 PDF 时优先使用的中文字体
# PDF_FONT_PATH=C:/Windows/Fonts/msyh.ttc

# 可选：长任务超时控制（毫秒）
# REPLICATE_IMAGE_TASK_TIMEOUT_MS=120000
# REPLICATE_AUDIO_TASK_TIMEOUT_MS=180000
# REPLICATE_VIDEO_TASK_TIMEOUT_MS=240000
